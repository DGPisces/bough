<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>dev.dgpisces.bough.usage-monitor</string>
	<key>BundleProgram</key>
	<string>Contents/Helpers/bough-usage-monitor</string>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<dict>
		<key>SuccessfulExit</key>
		<false/>
	</dict>
	<key>StandardOutPath</key>
	<string>/tmp/dev.dgpisces.bough.usage-monitor.out.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/dev.dgpisces.bough.usage-monitor.err.log</string>
</dict>
</plist>
